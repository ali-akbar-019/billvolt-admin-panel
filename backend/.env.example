# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/billvolt

# Redis (Upstash recommended)
# Powers refresh-token sessions (instant revocation) and can back rate
# limiting/caching later. App still runs without it, but sessions can't
# be revoked early.
REDIS_URL=

# Auth
JWT_SECRET=change_this_to_a_long_random_string
JWT_REFRESH_SECRET=change_this_to_a_different_long_random_string

# Field-level encryption (used for SSN and other sensitive Provider fields)
FIELD_ENCRYPTION_KEY=change_this_to_a_long_random_string

# Frontend URL (for CORS)
CLIENT_URL=http://localhost:5173
